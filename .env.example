# ============================================================
# 管理员 & 代理商平台 - Supabase 配置
# ============================================================
# 复制此文件为 .env.local 并填入真实值
# Vercel 部署时在 Project Settings → Environment Variables 中配置

# Supabase 项目 URL
# 获取地址：Supabase 控制台 → 项目 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 匿名访问密钥（客户端使用，安全，可以暴露给浏览器）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc..._your_anon_key_here

# Supabase 服务角色密钥（服务端 API 使用，敏感，请勿提交到 Git）
# 有完整数据库权限，仅用于服务端代码
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc..._your_service_role_key_here

# 网站公开 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# 部署说明
# ============================================================
#
# 1. 创建 Supabase 项目
#    访问 https://supabase.com 并创建新项目
#
# 2. 运行数据库架构脚本
#    在 Supabase SQL Editor 中运行 scripts/schema.sql
#    这将创建所有必要的表
#
# 3. 配置环境变量
#    - 本地开发：创建 .env.local 文件并填入上方的值
#    - Vercel 部署：在 Vercel 项目设置中添加环境变量
#
# 4. 数据迁移（如果有本地 JSON 数据）
#    运行：npm run migrate
#    这会从 data/ 目录读取 JSON 文件并导入到 Supabase
#
# 5. 部署到 Vercel
#    运行：vercel --prod
#    或在 vercel.com 上手动连接项目
#
# ============================================================
# 数据库表说明
# ============================================================
#
# - warehouses: 仓库信息
# - products: 产品信息（包含 SKU、价格、库存等）
# - agents: 代理商信息（包含登录账号、信用额度等）
# - orders: 订单信息（包含产品、运费、状态等）
# - credit_transactions: 信用额度交易记录
# - inventory_logs: 库存操作日志
# - employees: 员工账号（管理员后台登录）
#
# ============================================================
# 登录账号
# ============================================================
#
# 管理员后台：
#   Email: admin@company.com
#   Password: admin123   （首次部署时自动创建）
#
# 代理商后台：
#   代理商账号在管理员后台创建
#   Email: 代理商注册的邮箱
#   Password: 管理员设置的密码
#
# ============================================================
